{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug with DAP",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/SIZU_TASK.elf",
            "configFiles": [
                "${workspaceFolder}/openocd_dap.cfg"
            ],
            "device": "STM32F427II",
            "interface": "swd",
            "runToEntryPoint": "main",
            "svdFile": "${workspaceFolder}/STM32F427.svd",
            "showDevDebugOutput": "none",
            "rtos": "FreeRTOS",
            "preLaunchTask": "Download DAP",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        },
